// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  AGENT
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ContactStatus {
  ACTIVE
  BLOCKED
  UNSUBSCRIBED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  TEMPLATE
  INTERACTIVE
  LOCATION
  STICKER
  REACTION
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum CampaignLogLevel {
  INFO
  WARNING
  ERROR
}

enum WhatsAppAccountStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum WebhookEventType {
  MESSAGE_RECEIVED
  MESSAGE_STATUS_UPDATE
  TEMPLATE_STATUS_UPDATE
}

enum ChatbotChannel {
  WHATSAPP
  INSTAGRAM
  WEBCHAT
}

enum ChatbotTriggerType {
  MESSAGE_RECEIVED
  NEW_CONVERSATION
  NO_MATCH_REPLY
  RECEIVE_WEBHOOK
  TRIGGER_SEQUENCE
  KEYWORD_MATCH
  COMMENT_ON_POST
  STORY_REPLY
}

enum ChatbotStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum ChatbotSessionStatus {
  ACTIVE
  WAITING_REPLY
  COMPLETED
  FAILED
  TIMED_OUT
}

enum SequenceStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum SequenceEnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum SubscriptionPackage {
  FREE
  BASIC
  ADVANCE
  ADVANCE_5L
  ENTERPRISE
}

// ─── Models ────────────────────────────────────────────────────────────────

model Organization {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  logoUrl         String?
  website         String?
  address         String?
  whatsappNumber  String?
  expiryDate      DateTime?
  package         SubscriptionPackage @default(FREE)
  isPhoneVerified Boolean             @default(false)
  timezone        String              @default("UTC")
  status          OrganizationStatus  @default(ACTIVE)
  metadata        Json                @default("{}")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  users           User[]
  whatsappAccounts WhatsAppAccount[]
  contacts        Contact[]
  campaigns       Campaign[]
  messages        Message[]
  conversations   Conversation[]
  templates       WhatsAppTemplate[]
  webhookEvents   WebhookEvent[]
  customFields    CustomField[]
  chatbots        Chatbot[]
  sessions        ChatbotSession[]
  sequences       Sequence[]
  enrollments     SequenceEnrollment[]
  googleCredentials GoogleCredential[]

  @@map("organizations")
}

model User {
  id             String     @id @default(uuid())
  organizationId String
  email          String     @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole   @default(AGENT)
  status         UserStatus @default(ACTIVE)
  avatarUrl      String?
  lastIp         String?
  lastLoginAt    DateTime?
  refreshToken   String?
  timezone       String                   @default("UTC")
  permissions    Json                     @default("{}")
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accountAccess  WhatsAppAccountAccess[]
  activityLogs   ActivityLog[]
  googleCredentials GoogleCredential[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model WhatsAppAccountAccess {
  id                String   @id @default(uuid())
  userId            String
  whatsappAccountId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappAccount   WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, whatsappAccountId])
  @@index([userId])
  @@index([whatsappAccountId])
  @@map("whatsapp_account_access")
}

model WhatsAppAccount {
  id                  String                @id @default(uuid())
  organizationId      String
  displayName         String
  phoneNumber         String                @unique
  phoneNumberId       String                @unique
  wabaId              String                // WhatsApp Business Account ID
  accessToken         String                // encrypted at app level
  verifyToken         String                @unique
  webhookSecret       String
  status              WhatsAppAccountStatus @default(ACTIVE)
  businessProfile     Json                  @default("{}")
  messagingLimitTier  String?               @default("TIER_1000")
  messagingLimitCount Int                   @default(1000)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     Message[]
  conversations Conversation[]
  contacts     Contact[]       @relation("WhatsAppContacts")
  templates    WhatsAppTemplate[]
  accountAccess WhatsAppAccountAccess[]

  @@index([organizationId])
  @@index([wabaId])
  @@map("whatsapp_accounts")
}

model Contact {
  id              String        @id @default(uuid())
  organizationId  String
  whatsappId      String?       // WhatsApp's internal contact ID (wa_id)
  phone           String
  firstName       String?
  lastName        String?
  email           String?
  avatarUrl       String?
  status          ContactStatus @default(ACTIVE)
  tags            String[]      @default([])
  customFields    Json          @default("{}")
  agentId         String?       // Assigned Agent (User ID)
  optedInAt       DateTime?
  optedOutAt      DateTime?
  lastContactedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages        Message[]
  conversations   Conversation[]
  campaignRecipients CampaignRecipient[]
  whatsappAccounts WhatsAppAccount[] @relation("WhatsAppContacts")
  sessions        ChatbotSession[]
  enrollments     SequenceEnrollment[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([phone])
  @@map("contacts")
}

model CustomField {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  type           String       @default("TEXT")
  isRequired     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("custom_fields")
}

model Message {
  id              String           @id @default(uuid())
  organizationId  String
  whatsappAccountId String
  contactId       String
  waMessageId     String?          @unique // WhatsApp's message ID
  direction       MessageDirection
  type            MessageType      @default(TEXT)
  status          MessageStatus    @default(PENDING)
  content         Json             // flexible content structure per message type
  metadata        Json             @default("{}")
  conversationId  String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  failedAt        DateTime?
  failureReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  contact         Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversation    Conversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)

// failures        Message[]       @relation("MessageFailures")

  @@index([organizationId])
  @@index([whatsappAccountId])
  @@index([contactId])
  @@index([conversationId])
  @@index([waMessageId])
  @@index([direction, status])
  @@map("messages")
}

model Conversation {
  id                String   @id @default(uuid())
  organizationId    String
  whatsappAccountId String
  contactId         String
  lastMessageBody   String?
  lastMessageAt     DateTime @default(now())
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  contact         Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@unique([organizationId, whatsappAccountId, contactId])
  @@index([organizationId])
  @@index([whatsappAccountId])
  @@index([contactId])
  @@map("conversations")
}

model Campaign {
  id             String         @id @default(uuid())
  organizationId String
  name           String
  description    String?
  status         CampaignStatus @default(DRAFT)
  templateName   String?
  templateParams Json           @default("[]")
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  totalRecipients Int           @default(0)
  sentCount      Int            @default(0)
  deliveredCount Int            @default(0)
  readCount      Int            @default(0)
  failedCount    Int            @default(0)
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipients   CampaignRecipient[]
  logs         CampaignLog[]

  @@index([organizationId])
  @@index([status])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String        @id @default(uuid())
  campaignId String
  contactId  String
  status     MessageStatus @default(PENDING)
  sentAt     DateTime?
  deliveredAt DateTime?
  readAt     DateTime?
  failedAt   DateTime?
  failureReason String?
  createdAt  DateTime      @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
  @@map("campaign_recipients")
}

model CampaignLog {
  id         String           @id @default(uuid())
  campaignId String
  message    String
  level      CampaignLogLevel @default(INFO)
  metadata   Json             @default("{}")
  createdAt  DateTime         @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([level])
  @@map("campaign_logs")
}

model WebhookEvent {
  id             String           @id @default(uuid())
  organizationId String
  eventType      WebhookEventType
  payload        Json
  processed      Boolean          @default(false)
  processedAt    DateTime?
  error          String?
  retryCount     Int              @default(0)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([processed])
  @@index([eventType])
  @@map("webhook_events")
}

model WhatsAppTemplate {
  id              String   @id @default(uuid())
  organizationId  String
  accountId       String
  name            String   // Meta template name
  language        String
  category        String
  status          String   @default("APPROVED") // APPROVED, REJECTED, PENDING, etc.
  components      Json     // The raw components sent to Meta
  variableMapping Json     // e.g. { "1": "firstName", "2": "email", "3": "custom:EnglishMarks" }
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account        WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, name, language])
  @@index([organizationId])
  @@index([accountId])
  @@map("whatsapp_templates")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   Json     @default("{}")
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("activity_logs")
}

model Chatbot {
  id             String             @id @default(uuid())
  organizationId String
  name           String
  description    String?
  channel        ChatbotChannel
  triggerType    ChatbotTriggerType
  status         ChatbotStatus      @default(DRAFT)
  keywords       String[]           @default([])
  flowData       Json               @default("{}")
  executions     Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions       ChatbotSession[]

  @@index([organizationId])
  @@index([channel])
  @@index([status])
  @@map("chatbots")
}

model ChatbotSession {
  id              String               @id @default(uuid())
  organizationId  String
  chatbotId       String
  contactId       String
  accountId       String               // WhatsApp account ID
  currentNodeId   String
  variables       Json                 @default("{}")
  status          ChatbotSessionStatus @default(ACTIVE)
  waitingForInput Boolean              @default(false)
  waitingNodeType String?              // "button" | "list" | "ask"
  expiresAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chatbot         Chatbot      @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  contact         Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, status])
  @@index([organizationId])
  @@index([chatbotId])
  @@map("chatbot_sessions")
}

model Sequence {
  id             String         @id @default(uuid())
  organizationId String
  name           String
  description    String?
  status         SequenceStatus @default(DRAFT)
  triggerType    String         @default("MANUAL") // MANUAL | ON_CONTACT_CREATED | ON_TAG_ADDED
  triggerValue   String?        // e.g. tag name for ON_TAG_ADDED
  executions     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps          SequenceStep[]
  enrollments    SequenceEnrollment[]

  @@index([organizationId])
  @@map("sequences")
}

model SequenceStep {
  id          String   @id @default(uuid())
  sequenceId  String
  orderIndex  Int
  delayAmount Int      @default(0)
  delayUnit   String   @default("minutes") // seconds | minutes | hours | days
  actionType  String   // SEND_TEXT | SEND_TEMPLATE | SEND_MEDIA | SEND_BUTTON
  actionData  Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sequence    Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@map("sequence_steps")
}

model SequenceEnrollment {
  id               String                   @id @default(uuid())
  organizationId   String
  sequenceId       String
  contactId        String
  accountId        String
  currentStepIndex Int                      @default(0)
  status           SequenceEnrollmentStatus @default(ACTIVE)
  nextExecuteAt    DateTime?
  startedAt        DateTime                 @default(now())
  completedAt      DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sequence         Sequence      @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contact          Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, status])
  @@index([sequenceId])
  @@index([organizationId])
  @@map("sequence_enrollments")
}

model GoogleCredential {
  id             String   @id @default(uuid())
  organizationId String
  userId         String   
  accessToken    String   
  refreshToken   String   
  expiresAt      DateTime
  email          String   
  scopes         String[] 
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("google_credentials")
}
