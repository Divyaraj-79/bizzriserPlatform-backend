// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  AGENT
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ContactStatus {
  ACTIVE
  BLOCKED
  UNSUBSCRIBED
  DELETED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  TEMPLATE
  INTERACTIVE
  LOCATION
  STICKER
  REACTION
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum CampaignLogLevel {
  INFO
  WARNING
  ERROR
}

enum WhatsAppAccountStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum WebhookEventType {
  MESSAGE_RECEIVED
  MESSAGE_STATUS_UPDATE
  TEMPLATE_STATUS_UPDATE
  FLOW_STATUS_UPDATE
}

enum WhatsAppFlowStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
  BLOCKED
}

enum ChatbotChannel {
  WHATSAPP
  INSTAGRAM
  WEBCHAT
}

enum ChatbotTriggerType {
  MESSAGE_RECEIVED
  NEW_CONVERSATION
  NO_MATCH_REPLY
  RECEIVE_WEBHOOK
  TRIGGER_SEQUENCE
  KEYWORD_MATCH
  COMMENT_ON_POST
  STORY_REPLY
}

enum ChatbotStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum ChatbotSessionStatus {
  ACTIVE
  WAITING_REPLY
  COMPLETED
  FAILED
  TIMED_OUT
}

enum SequenceStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum SequenceEnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  POPUP
  TOAST
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  TRIAL_EXPIRED
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum InvitationStatus {
  PENDING
  REGISTERED
  ACTIVE
}

enum OfferCodeType {
  PERCENTAGE
  FIXED
}

model Package {
  id                      String   @id @default(uuid())
  name                    String   @unique
  description             String?
  
  monthlyPrice            Int      @default(0)
  quarterlyPrice          Int      @default(0)
  yearlyPrice             Int      @default(0)
  currency                String   @default("INR")
  
  razorpayMonthlyPlanId   String?
  razorpayQuarterlyPlanId String?
  razorpayYearlyPlanId    String?
  
  whatsappAccountLimit    Int?
  chatbotLimit            Int?
  teamMemberLimit         Int?
  contactImportLimit      Int?
  broadcastContactLimit   Int?
  broadcastAllowed        Boolean  @default(true)
  sequencesAllowed        Boolean  @default(true)
  
  credits                 Int      @default(0)
  features                Json     @default("[]")
  isActive                Boolean  @default(true)
  isContactOnly           Boolean  @default(false)
  sortOrder               Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organizations           Organization[]
  subscriptions           RazorpaySubscription[]

  @@map("packages")
}

// ─── Models ────────────────────────────────────────────────────────────────

model Organization {
  id          String             @id @default(uuid())
  name        String
  slug        String             @unique
  logoUrl         String?
  website         String?
  address         String?
  whatsappNumber  String?
  expiryDate      DateTime?
  packageId       String?
  package         Package?            @relation(fields: [packageId], references: [id])
  isPhoneVerified Boolean             @default(false)
  timezone        String              @default("UTC")
  status          OrganizationStatus  @default(ACTIVE)
  metadata        Json                @default("{}")
  credits         Float               @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  users           User[]
  whatsappAccounts WhatsAppAccount[]
  contacts        Contact[]
  campaigns       Campaign[]
  messages        Message[]
  conversations   Conversation[]
  templates       WhatsAppTemplate[]
  webhookEvents   WebhookEvent[]
  customFields    CustomField[]
  chatbots        Chatbot[]
  sessions        ChatbotSession[]
  sequences       Sequence[]
  enrollments     SequenceEnrollment[]
  googleCredentials GoogleCredential[]
  customRoles     CustomRole[]
  contactNotes    ContactNote[]
  cannedResponses CannedResponse[]
  whatsappFlows   WhatsAppFlow[]
  whatsappFlowSubmissions WhatsAppFlowSubmission[]
  userInputFlows          UserInputFlow[]
  metaCommerceConnection  MetaCommerceConnection?
  metaCatalogs            MetaCatalog[]
  metaProducts            MetaProduct[]
  catalogOrders           CatalogOrder[]
  manualPayments          ManualPayment[]
  catalogCoupons          CatalogCoupon[]

  // New Subscription / Trial fields
  orgCode             String?             @unique
  subscriptionStatus  SubscriptionStatus  @default(TRIAL)
  billingCycle        BillingCycle?
  trialEndsAt         DateTime?
  subscriptionId      String?
  subscriptionEndsAt  DateTime?
  razorpayCustomerId  String?
  
  subscriptions       RazorpaySubscription[]
  clientInvitation    ClientInvitation?

  @@map("organizations")
}

model User {
  id             String     @id @default(uuid())
  organizationId String
  email          String     @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           UserRole   @default(AGENT)
  status         UserStatus @default(ACTIVE)
  avatarUrl      String?
  lastIp         String?
  lastLoginAt    DateTime?
  refreshToken   String?
  timezone       String                   @default("UTC")
  permissions    Json                     @default("{}")
  resetOtp       String?
  resetOtpExpiry DateTime?
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  lastSeenVersion String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accountAccess  WhatsAppAccountAccess[]
  activityLogs   ActivityLog[]
  googleCredentials GoogleCredential[]
  contactNotes   ContactNote[]
  notificationReads NotificationRead[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model ClientInvitation {
  id              String           @id @default(uuid())
  email           String           @unique
  firstName       String
  lastName        String
  status          InvitationStatus @default(PENDING)
  tempPasswordHash String?
  organizationId  String?          @unique
  organization    Organization?    @relation(fields: [organizationId], references: [id])
  preRegisteredBy String?
  ipAddress       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("client_invitations")
}

model RazorpaySubscription {
  id                    String             @id @default(uuid())
  organizationId        String
  razorpaySubscriptionId String            @unique
  razorpayCustomerId    String?
  razorpayPaymentId     String?
  packageId             String
  package               Package            @relation(fields: [packageId], references: [id])
  billingCycle          BillingCycle
  currency              String             @default("INR")
  amount                Int
  status                SubscriptionStatus
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  offerCodeId           String?
  discountAmount        Int                @default(0)
  webhookVerified       Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  organization          Organization       @relation(fields: [organizationId], references: [id])

  @@map("razorpay_subscriptions")
}

model OfferCode {
  id              String        @id @default(uuid())
  code            String        @unique
  type            OfferCodeType
  value           Int
  maxUses         Int?
  usedCount       Int           @default(0)
  validFrom       DateTime?
  validUntil      DateTime?
  applicablePlans String[]      @default([])
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("offer_codes")
}

model CustomRole {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  permissions    Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@map("custom_roles")
}

model WhatsAppAccountAccess {
  id                String   @id @default(uuid())
  userId            String
  whatsappAccountId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappAccount   WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, whatsappAccountId])
  @@index([userId])
  @@index([whatsappAccountId])
  @@map("whatsapp_account_access")
}

model WhatsAppAccount {
  id                  String                @id @default(uuid())
  organizationId      String
  displayName         String
  phoneNumber         String                @unique
  phoneNumberId       String                @unique
  wabaId              String                // WhatsApp Business Account ID
  accessToken         String                // encrypted at app level
  verifyToken         String                @unique
  webhookSecret       String
  status              WhatsAppAccountStatus @default(ACTIVE)
  businessProfile     Json                  @default("{}")
  messagingLimitTier  String?               @default("TIER_1000")
  messagingLimitCount Int                   @default(1000)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     Message[]
  conversations Conversation[]
  contacts     Contact[]       @relation("WhatsAppContacts")
  templates    WhatsAppTemplate[]
  accountAccess WhatsAppAccountAccess[]

  @@index([organizationId])
  @@index([wabaId])
  @@map("whatsapp_accounts")
}

model Contact {
  id              String        @id @default(uuid())
  organizationId  String
  whatsappId      String?       // WhatsApp's internal contact ID (wa_id)
  phone           String
  firstName       String?
  lastName        String?
  email           String?
  avatarUrl       String?
  status          ContactStatus @default(ACTIVE)
  tags            String[]      @default([])
  customFields    Json          @default("{}")
  agentId         String?       // Assigned Agent (User ID)
  optedInAt       DateTime?
  optedOutAt      DateTime?
  lastContactedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages        Message[]
  conversations   Conversation[]
  campaignRecipients CampaignRecipient[]
  whatsappAccounts WhatsAppAccount[] @relation("WhatsAppContacts")
  sessions        ChatbotSession[]
  enrollments     SequenceEnrollment[]
  notes           ContactNote[]
  whatsappFlowSubmissions WhatsAppFlowSubmission[]

  @@unique([organizationId, phone])
  @@index([organizationId])
  @@index([phone])
  @@index([organizationId, updatedAt])
  @@index([organizationId, status])
  @@map("contacts")
}

model CustomField {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  type           String       @default("TEXT")
  isRequired     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("custom_fields")
}

model Message {
  id              String           @id @default(uuid())
  organizationId  String
  whatsappAccountId String
  contactId       String
  waMessageId     String?          @unique // WhatsApp's message ID
  direction       MessageDirection
  type            MessageType      @default(TEXT)
  status          MessageStatus    @default(PENDING)
  isHidden        Boolean          @default(false)
  content         Json             // flexible content structure per message type
  metadata        Json             @default("{}")
  conversationId  String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  failedAt        DateTime?
  failureReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  contact         Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversation    Conversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)

// failures        Message[]       @relation("MessageFailures")

  @@index([organizationId])
  @@index([whatsappAccountId])
  @@index([contactId])
  @@index([conversationId])
  @@index([waMessageId])
  @@index([direction, status])
  @@index([organizationId, createdAt])
  @@map("messages")
}

model Conversation {
  id                String   @id @default(uuid())
  organizationId    String
  whatsappAccountId String
  contactId         String
  lastMessageBody   String?
  lastMessageAt     DateTime @default(now())
  unreadCount       Int      @default(0)
  section           String   @default("PRIMARY")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  contact         Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@unique([organizationId, whatsappAccountId, contactId])
  @@index([organizationId])
  @@index([organizationId, section, lastMessageAt])
  @@index([whatsappAccountId])
  @@index([contactId])
  @@map("conversations")
}

model Campaign {
  id             String         @id @default(uuid())
  organizationId String
  name           String
  description    String?
  status         CampaignStatus @default(DRAFT)
  templateName   String?
  templateParams Json           @default("[]")
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  totalRecipients Int           @default(0)
  sentCount      Int            @default(0)
  deliveredCount Int            @default(0)
  readCount      Int            @default(0)
  failedCount    Int            @default(0)
  responseCount  Int            @default(0)
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipients   CampaignRecipient[]
  logs         CampaignLog[]

  @@index([organizationId])
  @@index([status])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String        @id @default(uuid())
  campaignId String
  contactId  String
  status     MessageStatus @default(PENDING)
  sentAt     DateTime?
  deliveredAt DateTime?
  readAt     DateTime?
  failedAt   DateTime?
  failureReason String?
  firstResponse String?
  firstResponseAt DateTime?
  createdAt  DateTime      @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
  @@map("campaign_recipients")
}

model CampaignLog {
  id         String           @id @default(uuid())
  campaignId String
  message    String
  level      CampaignLogLevel @default(INFO)
  metadata   Json             @default("{}")
  createdAt  DateTime         @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([level])
  @@map("campaign_logs")
}

model WebhookEvent {
  id             String           @id @default(uuid())
  organizationId String
  eventType      WebhookEventType
  payload        Json
  processed      Boolean          @default(false)
  processedAt    DateTime?
  error          String?
  retryCount     Int              @default(0)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([processed])
  @@index([eventType])
  @@map("webhook_events")
}

model WhatsAppTemplate {
  id              String   @id @default(uuid())
  organizationId  String
  accountId       String
  name            String   // Meta template name
  language        String
  category        String
  status          String   @default("APPROVED") // APPROVED, REJECTED, PENDING, etc.
  qualityScore    Json?    // Stores Meta's quality_score object e.g. { "score": "GREEN", "date": 12345 }
  components      Json     // The raw components sent to Meta
  variableMapping Json     // e.g. { "1": "firstName", "2": "email", "3": "custom:EnglishMarks" }
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account        WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, name, language])
  @@index([organizationId])
  @@index([accountId])
  @@map("whatsapp_templates")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   Json     @default("{}")
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("activity_logs")
}

model Chatbot {
  id             String             @id @default(uuid())
  organizationId String
  name           String
  description    String?
  channel        ChatbotChannel
  triggerType    ChatbotTriggerType
  status         ChatbotStatus      @default(DRAFT)
  keywords       String[]           @default([])
  flowData       Json               @default("{}")
  executions     Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions       ChatbotSession[]

  @@index([organizationId])
  @@index([channel])
  @@index([status])
  @@map("chatbots")
}

model ChatbotSession {
  id              String               @id @default(uuid())
  organizationId  String
  chatbotId       String
  contactId       String
  accountId       String               // WhatsApp account ID
  currentNodeId   String
  variables       Json                 @default("{}")
  metadata        Json                 @default("{}")
  status          ChatbotSessionStatus @default(ACTIVE)
  waitingForInput Boolean              @default(false)
  waitingNodeType String?              // "button" | "list" | "ask"
  expiresAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chatbot         Chatbot      @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  contact         Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, status])
  @@index([organizationId])
  @@index([chatbotId])
  @@map("chatbot_sessions")
}

model Sequence {
  id             String         @id @default(uuid())
  organizationId String
  name           String
  description    String?
  status         SequenceStatus @default(DRAFT)
  triggerType    String         @default("MANUAL") // MANUAL | ON_CONTACT_CREATED | ON_TAG_ADDED
  triggerValue   String?        // e.g. tag name for ON_TAG_ADDED
  executions     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps          SequenceStep[]
  enrollments    SequenceEnrollment[]

  @@index([organizationId])
  @@map("sequences")
}

model SequenceStep {
  id          String   @id @default(uuid())
  sequenceId  String
  orderIndex  Int
  delayAmount Int      @default(0)
  delayUnit   String   @default("minutes") // seconds | minutes | hours | days
  actionType  String   // SEND_TEXT | SEND_TEMPLATE | SEND_MEDIA | SEND_BUTTON
  actionData  Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sequence    Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@map("sequence_steps")
}

model SequenceEnrollment {
  id               String                   @id @default(uuid())
  organizationId   String
  sequenceId       String
  contactId        String
  accountId        String
  currentStepIndex Int                      @default(0)
  status           SequenceEnrollmentStatus @default(ACTIVE)
  nextExecuteAt    DateTime?
  startedAt        DateTime                 @default(now())
  completedAt      DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sequence         Sequence      @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contact          Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, status])
  @@index([sequenceId])
  @@index([organizationId])
  @@map("sequence_enrollments")
}

model GoogleCredential {
  id             String   @id @default(uuid())
  organizationId String
  userId         String   
  accessToken    String   
  refreshToken   String   
  expiresAt      DateTime
  email          String   
  scopes         String[] 
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("google_credentials")
}

model ContactNote {
  id             String   @id @default(uuid())
  organizationId String
  contactId      String
  userId         String   // Author
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author         User         @relation(fields: [userId], references: [id])

  @@index([contactId])
  @@map("contact_notes")
}

model CannedResponse {
  id             String   @id @default(uuid())
  organizationId String
  shortcut       String   // e.g. "greet"
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, shortcut])
  @@index([organizationId])
  @@map("canned_responses")
}

model WhatsAppFlow {
  id             String             @id @default(uuid())
  organizationId String
  name           String
  description    String?
  flowId         String?            @unique // Meta's ID
  definition     Json               @default("{}")
  status         WhatsAppFlowStatus @default(DRAFT)
  version        Int                @default(1)
  categories     String[]           @default(["OTHER"])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submissions    WhatsAppFlowSubmission[]

  @@index([organizationId])
  @@map("whatsapp_flows")
}

model WhatsAppFlowSubmission {
  id             String       @id @default(uuid())
  organizationId String
  flowId         String       // Local WhatsAppFlow ID
  contactId      String
  data           Json         // The actual form results
  submittedAt    DateTime     @default(now())
  
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flow           WhatsAppFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@index([contactId])
  @@map("whatsapp_flow_submissions")
}

model UserInputFlow {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  description    String?
  config         Json         @default("[]")
  webhookUrl     String?
  googleSheetId  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("user_input_flows")
}

model MetaCommerceConnection {
  id             String       @id @default(uuid())
  organizationId String       @unique
  accessToken    String
  businessId     String?
  catalogId      String?
  outOfStockBehavior String @default("MARK_OUT_OF_STOCK")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("meta_commerce_connections")
}

model MetaCatalog {
  id               String          @id @default(uuid())
  organizationId   String
  metaCatalogId    String
  name             String
  isPublic         Boolean         @default(false)
  settings         Json            @default("{}")
  messageTemplates Json            @default("{}")
  productCount     Int             @default(0)
  lastSyncedAt     DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  coupons          CatalogCoupon[]
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("meta_catalogs")
}

model CatalogOrder {
  id              String       @id @default(uuid())
  organizationId  String
  catalogId       String
  orderUniqueId   String?
  buyerPhone      String?
  buyerName       String?
  amount          Float?
  currency        String?
  status          String       @default("PENDING")
  shippingAddress Json         @default("{}")
  reminderSentAt  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  metadata        Json         @default("{}")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("catalog_orders")
}

model ManualPayment {
  id             String       @id @default(uuid())
  organizationId String
  catalogId      String
  buyerName      String?
  amount         Float?
  currency       String?
  attachmentUrl  String?
  status         String       @default("PENDING_VERIFICATION")
  additionalInfo String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("manual_payments")
}

model CatalogCoupon {
  id             String       @id @default(uuid())
  organizationId String
  catalogId      String
  code           String
  type           String       @default("PERCENTAGE")
  value          Float        @default(0)
  minOrder       Float        @default(0)
  maxUses        Int          @default(0)
  usedCount      Int          @default(0)
  isActive       Boolean      @default(true)
  validFrom      DateTime?
  validTo        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  metaCatalog    MetaCatalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([catalogId])
  @@index([organizationId])
  @@map("catalog_coupons")
}

model OtpRateLimit {
  id         String    @id @default(uuid())
  identifier String    @unique
  count      Int       @default(0)
  resetAt    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("otp_rate_limits")
}

enum NotificationCategory {
  // System
  MAINTENANCE
  DISRUPTION
  SECURITY
  // Billing
  BILLING
  CREDITS
  SUBSCRIPTION
  // WhatsApp
  WA_ACCOUNT
  WA_TEMPLATE
  // Product
  NEW_FEATURE
  CHANGELOG
  DEPRECATION
  // Engagement
  OFFER
  GREETING
  MILESTONE
  // General
  INFO
  ALERT
  SUCCESS
  WARNING
  RESTRICTION
}

enum NotificationAudience {
  ALL
  ORG_ADMINS
  SUPER_ADMIN
  SPECIFIC_ORGS
  SPECIFIC_PLAN
}

enum NotificationPriority {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
}

enum NotificationStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

model SystemNotification {
  id             String                   @id @default(uuid())
  title          String
  message        String
  ctaLabel       String?
  ctaUrl         String?
  imageUrl       String?
  
  type           NotificationType         @default(TOAST)
  category       NotificationCategory     @default(INFO)
  priority       NotificationPriority     @default(NORMAL)
  
  audience       NotificationAudience     @default(ALL)
  targetOrgIds   String[]                 @default([])
  targetPlanId   String?
  
  channels       NotificationChannel[]    @default([IN_APP])
  
  isScheduled    Boolean                  @default(false)
  scheduledFor   DateTime?
  
  expiresAt      DateTime?
  isPinned       Boolean                  @default(false)
  isActive       Boolean                  @default(true)
  
  status         NotificationStatus       @default(DRAFT)
  sentAt         DateTime?
  recipientCount Int                      @default(0)
  
  createdBy      String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  reads          NotificationRead[]
  deliveries     NotificationDelivery[]

  @@map("system_notifications")
}

model NotificationRead {
  id             String             @id @default(uuid())
  userId         String
  notificationId String
  isDismissed    Boolean            @default(false)
  viewedAt       DateTime?
  createdAt      DateTime           @default(now())

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification   SystemNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
  @@map("notification_reads")
}

model NotificationDelivery {
  id               String               @id @default(uuid())
  notificationId   String
  channel          NotificationChannel
  status           String
  recipientCount   Int                  @default(0)
  sentAt           DateTime?
  errorMessage     String?

  notification     SystemNotification   @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@map("notification_deliveries")
}

model AppVersion {
  id          String   @id @default(uuid())
  version     String   @unique
  title       String
  highlights  String[]
  changelog   String?
  isPublished Boolean  @default(false)
  notifyUsers Boolean  @default(true)
  isScheduled Boolean  @default(false)
  scheduledFor DateTime?
  createdAt   DateTime @default(now())
  publishedAt DateTime?

  @@map("app_versions")
}

model MetaProduct {
  id              String   @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  metaCatalogId   String
  
  metaId          String?  // Meta's node ID
  retailerId      String   // SKU / Content ID
  
  name            String
  description     String?  @db.Text
  price           String?
  currency        String?
  image_url       String?
  url             String?
  brand           String?
  availability    String?
  condition       String?
  category        String?
  
  itemGroupId     String?
  inventory       Int?
  salePrice       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, metaCatalogId, retailerId])
  @@index([organizationId, metaCatalogId])
  @@map("meta_products")
}
